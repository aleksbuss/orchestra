# === Orchestra Configuration ===

# OpenAI (required for default model)
OPENAI_API_KEY=sk-...

# Anthropic (optional)
ANTHROPIC_API_KEY=sk-ant-...

# Google (optional)
GOOGLE_API_KEY=...

# OpenRouter (optional)

OPENROUTER_API_KEY=sk-or-...

# Tavily Search (optional - for web search)
TAVILY_API_KEY=tvly-...

# External integrations API token (optional fallback for /api/external/message)
EXTERNAL_API_TOKEN=orchestra-local-token

# App auth session secret — REQUIRED in production; refusal-to-start otherwise.
# Generate a long random value (DO NOT commit it):
#   openssl rand -base64 48
# Then paste the output below. Each deployment must have its OWN secret —
# never reuse this value across environments or copy it from a tutorial.
ORCHESTRA_AUTH_SECRET=

# Telegram integration (optional; UI can auto-configure from bot token only)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_DEFAULT_PROJECT_ID=

# Docker runtime bind settings
APP_BIND_HOST=127.0.0.1
APP_PORT=3000

# Optional Docker runtime cache/temp paths (inside container).
# Defaults are defined in docker-compose.yml and usually do not need overrides.
# APP_TMP_DIR=/app/data/tmp
# PLAYWRIGHT_BROWSERS_PATH=/app/data/ms-playwright
# NPM_CONFIG_CACHE=/app/data/npm-cache
# XDG_CACHE_HOME=/app/data/.cache

# Optional CLI OAuth credential file overrides (for codex-cli / gemini-cli provider auth checks).
# If unset, Orchestra auto-discovers files in common home directories.
# Useful when Orchestra runs under a different user than the CLI login user.
# CODEX_AUTH_FILE=/home/node/.codex/auth.json
# GEMINI_OAUTH_CREDS_FILE=/home/node/.gemini/oauth_creds.json
# GEMINI_SETTINGS_FILE=/home/node/.gemini/settings.json

APP_BASE_URL=http://localhost:3000
